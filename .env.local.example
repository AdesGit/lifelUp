# Convex
NEXT_PUBLIC_CONVEX_URL=https://convex.aidigitalassistant.cloud

# Set by `npx convex deploy` or `npx convex dev`
# CONVEX_DEPLOYMENT=

# For self-hosted Convex deploys (do NOT commit these)
# CONVEX_SELF_HOSTED_URL=http://localhost:3210
# CONVEX_SELF_HOSTED_ADMIN_KEY=convex-self-hosted|...

# Auth (set in Convex dashboard env vars, not here)
# JWT_PRIVATE_KEY=
# JWKS=
# SITE_URL=https://lifelup.aidigitalassistant.cloud
